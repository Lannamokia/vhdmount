<Window x:Class="VHDMountAdminTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VHD Mount Admin Tools" Height="860" Width="1024">
    <DockPanel>
        <!-- 底部状态栏 + 关闭按钮（固定，不参与滚动） -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,8,16,12">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="关闭" Padding="8,2" Width="64" Click="CloseApp"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="16,16,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="更新签名密钥" Grid.Row="0">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="输出目录" VerticalAlignment="Center"/>
                        <TextBox x:Name="KeyOutDir" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Column="2" Content="浏览" Padding="12,4" MinWidth="64" MinHeight="28" Click="BrowseFolderKeyOut"/>

                        <TextBlock Grid.Row="2" Text="KeyId" VerticalAlignment="Center"/>
                        <TextBox x:Name="KeyIdBox" Grid.Row="2" Grid.Column="1" Margin="8,0" Text="update-key-2026-q2" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="生成签名密钥" Padding="12,4" MinWidth="96" MinHeight="28" Click="GenerateSigningKey"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="清单打包与签名" Grid.Row="2">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="payload 目录" VerticalAlignment="Center"/>
                        <TextBox x:Name="PayloadDir" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Column="2" Content="浏览" Padding="12,4" MinWidth="64" MinHeight="28" Click="BrowseFolderPayload"/>

                        <TextBlock Grid.Row="2" Text="输出目录" VerticalAlignment="Center"/>
                        <TextBox x:Name="ManifestOutDir" Grid.Row="2" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="浏览" Padding="12,4" MinWidth="64" MinHeight="28" Click="BrowseFolderManifestOut"/>

                        <TextBlock Grid.Row="4" Text="私钥文件" VerticalAlignment="Center"/>
                        <TextBox x:Name="PrivateKeyPath" Grid.Row="4" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="4" Grid.Column="2" Content="选择" Padding="12,4" MinWidth="64" MinHeight="28" Click="BrowsePrivateKey"/>

                        <TextBlock Grid.Row="6" Text="类型" VerticalAlignment="Center"/>
                        <ComboBox x:Name="TypeBox" Grid.Row="6" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26">
                            <ComboBoxItem Content="app-update" IsSelected="True"/>
                            <ComboBoxItem Content="vhd-data"/>
                        </ComboBox>

                        <TextBlock Grid.Row="8" Text="最小版本" VerticalAlignment="Center"/>
                        <TextBox x:Name="MinVersionBox" Grid.Row="8" Grid.Column="1" Margin="8,0" Text="1.5.0" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="10" Text="版本" VerticalAlignment="Center"/>
                        <TextBox x:Name="VersionBox" Grid.Row="10" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="10" Grid.Column="2" Content="生成清单并签名" Padding="12,4" MinWidth="96" MinHeight="28" Click="MakeManifest"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="预配置注册证书包" Grid.Row="4">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="输出目录" VerticalAlignment="Center"/>
                        <TextBox x:Name="RegistrationOutDir" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Column="2" Content="浏览" Padding="12,4" MinWidth="64" MinHeight="28" Click="BrowseFolderRegistrationOut"/>

                        <TextBlock Grid.Row="2" Text="Bundle 名称" VerticalAlignment="Center"/>
                        <TextBox x:Name="RegistrationBundleNameBox" Grid.Row="2" Grid.Column="1" Margin="8,0" Text="machine-registration" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="4" Text="证书主题 CN" VerticalAlignment="Center"/>
                        <TextBox x:Name="RegistrationSubjectBox" Grid.Row="4" Grid.Column="1" Margin="8,0" Text="VHDMount Machine Registration" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="6" Text="PFX 密码" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="RegistrationPasswordBox" Grid.Row="6" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="8" Text="有效天数" VerticalAlignment="Center"/>
                        <TextBox x:Name="RegistrationValidDaysBox" Grid.Row="8" Grid.Column="1" Margin="8,0" Text="365" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="10" Grid.Column="1" Margin="8,0,8,0" TextWrapping="Wrap" VerticalAlignment="Center"
                                   Text="将输出 .pfx、.pem、可信证书 JSON 和客户端配置片段，供服务器初始化与 VHDMounter 配置使用。"/>
                        <Button Grid.Row="10" Grid.Column="2" Content="生成证书包" Padding="12,4" MinWidth="96" MinHeight="28" Click="GenerateRegistrationBundle"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="软件部署包打包器" Grid.Row="6">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="包类型" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PackTypeBox" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26">
                            <ComboBoxItem Content="software-deploy" IsSelected="True"/>
                            <ComboBoxItem Content="file-deploy"/>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Text="安装脚本" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackInstallScript" Grid.Row="2" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="选择" Padding="12,4" MinWidth="64" MinHeight="28" Click="PackBrowseInstallScript"/>

                        <TextBlock Grid.Row="4" Text="卸载脚本" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackUninstallScript" Grid.Row="4" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="4" Grid.Column="2" Content="选择" Padding="12,4" MinWidth="64" MinHeight="28" Click="PackBrowseUninstallScript"/>

                        <TextBlock Grid.Row="6" Text="文件负载目录" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackPayloadDir" Grid.Row="6" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="6" Grid.Column="2" Content="浏览" Padding="12,4" MinWidth="64" MinHeight="28" Click="PackBrowsePayloadDir"/>

                        <TextBlock Grid.Row="8" Text="包名称" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackName" Grid.Row="8" Grid.Column="1" Margin="8,0" Text="配套工具" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="10" Text="版本号" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackVersion" Grid.Row="10" Grid.Column="1" Margin="8,0" Text="1.0.0" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="12" Text="签名者" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackSigner" Grid.Row="12" Grid.Column="1" Margin="8,0" Text="admin" VerticalAlignment="Center" MinHeight="26"/>

                        <TextBlock Grid.Row="14" Text="私钥文件" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackPrivateKey" Grid.Row="14" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="14" Grid.Column="2" Content="选择" Padding="12,4" MinWidth="64" MinHeight="28" Click="PackBrowsePrivateKey"/>

                        <TextBlock Grid.Row="16" Text="输出目录" VerticalAlignment="Center"/>
                        <TextBox x:Name="PackOutDir" Grid.Row="16" Grid.Column="1" Margin="8,0" VerticalAlignment="Center" MinHeight="26"/>
                        <Button Grid.Row="16" Grid.Column="2" Content="浏览" Padding="12,4" MinWidth="64" MinHeight="28" Click="PackBrowseOutDir"/>

                        <TextBlock Grid.Row="18" Grid.Column="1" Margin="8,0" TextWrapping="Wrap" VerticalAlignment="Center"
                                   Text="software-deploy 类型必须包含 install.ps1；file-deploy 类型不含脚本，只解压文件。输出文件为 name-version.zip 和 .zip.sig，可手动上传到服务端。"/>
                        <Button Grid.Row="18" Grid.Column="2" Content="打包并签名" Padding="16,6" MinWidth="96" MinHeight="32" Click="PackAndSign"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
