<Window x:Class="VHDMounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VHD Mounter"
        WindowState="Maximized"
        WindowStyle="None"
        Topmost="True"
        Background="White"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="9*"/>
        </Grid.RowDefinitions>

        <!--
            文档里的主视觉内容集中在底部 1080x1080 容器内。
            这里用 43.75% / 56.25% 的相对分区模拟该区域，并将状态组居中到容器圆心。
        -->
        <Grid Grid.Row="1" x:Name="CircularDisplayRegionHost">
            <Grid Width="{Binding ActualHeight, ElementName=CircularDisplayRegionHost}"
                  Height="{Binding ActualHeight, ElementName=CircularDisplayRegionHost}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="720">
                    <!-- 状态显示 -->
                    <TextBlock x:Name="StatusText"
                               Text="正在初始化..."
                               FontSize="24"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"
                               Foreground="Black"/>

                    <!-- VHD选择器 -->
                    <StackPanel x:Name="VHDSelector" Visibility="Collapsed">
                        <TextBlock Text="发现多个VHD文件，请选择一个:"
                                   FontSize="18"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"
                                   Foreground="Black"/>

                        <ListBox x:Name="VHDListBox"
                                 Width="600"
                                 Height="300"
                                 FontSize="14"
                                 SelectionMode="Single"
                                 Background="#F0F0F0"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Padding="10,5" Foreground="Black"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="使用上下键选择，回车确认"
                                   FontSize="14"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   Foreground="Gray"/>
                    </StackPanel>

                    <!-- 进度指示器（仅在本地更新阶段显示） -->
                    <ProgressBar x:Name="ProgressBar"
                                 Width="400"
                                 Height="20"
                                 Margin="0,24,0,0"
                                 IsIndeterminate="False"
                                 Minimum="0"
                                 Maximum="100"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
